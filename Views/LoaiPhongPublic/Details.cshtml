@model QLKS.Models.LoaiPhong
@{
    ViewData["Title"] = Model.TenLoai;

    var img = string.IsNullOrWhiteSpace(Model.HinhAnh)
        ? Url.Content("~/redplanet/images/img_1.jpg")
        : Url.Content(Model.HinhAnh);
}

<!-- DETAILS_V2_OK -->

<section class="site-hero overlay qlks-hero-mini" style="background-image: url('@img')">
    <div class="container">
        <div class="row site-hero-inner justify-content-center align-items-center">
            <div class="col-md-10 text-center">
                <h1 class="heading mb-3">@Model.TenLoai</h1>
                <p class="lead text-white-50 mb-0">
                    @string.Format("{0:N0}", Model.GiaMoiDem) VND / đêm · @Model.SoNguoi người
                </p>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row">

            <div class="col-lg-7 mb-4" data-aos="fade-up">
                <div class="bg-light p-3 p-md-4 rounded">
                    <img src="@img" class="img-fluid rounded mb-4" alt="@Model.TenLoai"
                         style="width:100%; height:360px; object-fit:cover;" />

                    <h3 class="mb-3">Mô tả</h3>

                    @if (!string.IsNullOrWhiteSpace(Model.MoTa))
                    {
                        <p class="mb-0">@Model.MoTa</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Chưa có mô tả cho loại phòng này.</p>
                    }
                </div>
            </div>

            <div class="col-lg-5" data-aos="fade-up" data-aos-delay="100">
                <div class="bg-white p-4 rounded shadow-sm">
                    <h4 class="mb-3">Thông tin & Giá</h4>

                    <ul class="list-unstyled mb-4">
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span>Sức chứa</span>
                            <b>@Model.SoNguoi người</b>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span>Giá</span>
                            <b>@string.Format("{0:N0}", Model.GiaMoiDem) VND / đêm</b>
                        </li>
                        <li class="d-flex justify-content-between py-2">
                            <span>Mã loại</span>
                            <b>#@Model.Id</b>
                        </li>
                    </ul>

                    <div class="alert alert-light border">
                        Chọn ngày nhận/trả để hệ thống tìm phòng trống theo lịch.
                    </div>

                    <div class="mt-3">
                        <a class="btn btn-primary btn-block"
                           asp-controller="Booking" asp-action="Search"
                           asp-route-loaiPhongId="@Model.Id">
                            Tìm phòng trống
                        </a>

                        <a class="btn btn-outline-secondary btn-block" asp-action="Index">
                            Xem các loại phòng
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
