@{
    var title = ViewData["Title"] as string ?? "QLKS";
    var userName = User?.Identity?.Name ?? "";
    var initial = string.IsNullOrWhiteSpace(userName) ? "U" : userName.Trim()[0].ToString().ToUpperInvariant();

    // ✅ Cho phép mỗi trang set class cho body (vd: "qlks-auth-page")
    var bodyClass = (ViewData["BodyClass"] as string) ?? "";
    bodyClass = bodyClass.Trim();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@title - QLKS</title>

    <link rel="stylesheet" type="text/css" href="//fonts.googleapis.com/css?family=Roboto+Sans:400,700|Playfair+Display:400,700">

    <link rel="stylesheet" href="~/redplanet/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/css/animate.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/css/owl.carousel.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/css/aos.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/css/bootstrap-datepicker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/css/jquery.timepicker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/css/fancybox.min.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/redplanet/fonts/ionicons/css/ionicons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/fonts/fontawesome/css/font-awesome.min.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/redplanet/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/redplanet/css/qlks-user.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body class="qlks-user-body @bodyClass" data-spy="scroll" data-target="#templateux-navbar" data-offset="200">

    <nav class="navbar navbar-expand-lg navbar-dark pb_navbar pb_scrolled-light" id="templateux-navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="text-danger">QL</span>KS
            </a>

            <div class="site-menu-toggle js-site-menu-toggle ml-auto"
                 data-toggle="collapse"
                 data-target="#templateux-navbar-nav"
                 aria-controls="templateux-navbar-nav"
                 aria-expanded="false"
                 aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </div>

            <div class="collapse navbar-collapse" id="templateux-navbar-nav">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="LoaiPhongPublic" asp-action="Index">Loại phòng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Booking" asp-action="Search">Tìm phòng trống</a>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="MyBookings">Đơn đặt của tôi</a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Quản trị</a>
                        </li>
                    }

                    <li class="nav-item cta-btn ml-xl-2 ml-lg-2 ml-md-0 ml-sm-0 ml-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a class="nav-link" asp-controller="Booking" asp-action="Search">
                                <span class="pb_rounded-4 px-4 rounded">Đặt phòng ngay</span>
                            </a>
                        }
                        else
                        {
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <span class="pb_rounded-4 px-4 rounded">Đăng nhập</span>
                            </a>
                        }
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ml-lg-3 mt-2 mt-lg-0 d-flex align-items-center">
                            <span class="text-white-50 small mr-2">
                                Hi, <b class="text-white">@User.Identity!.Name</b>
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-light">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ml-lg-2">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @{
        bool hasAlert =
        TempData["success"] != null ||
        TempData["msg"] != null ||
        TempData["warning"] != null ||
        TempData["error"] != null;
    }

    @if (hasAlert)
    {
        <div class="container qlks-alerts">
            @if (TempData["success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["success"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            }
            @if (TempData["msg"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    @TempData["msg"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            }
            @if (TempData["warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    @TempData["warning"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            }
            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["error"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            }
        </div>
    }

    <main class="qlks-user-main">
        @RenderBody()
    </main>

    <footer class="section bg-light" style="padding: 48px 0;">
        <div class="container text-center">
            <div class="small text-muted">© @DateTime.Now.Year - QLKS</div>
        </div>
    </footer>

    <script src="~/redplanet/js/jquery-3.3.1.min.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/jquery-migrate-3.0.1.min.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/popper.min.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/bootstrap.min.js" asp-append-version="true"></script>

    <script src="~/redplanet/js/owl.carousel.min.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/jquery.stellar.min.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/jquery.fancybox.min.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/jquery.easing.1.3.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/aos.js" asp-append-version="true"></script>
    <script src="~/redplanet/js/main.js" asp-append-version="true"></script>

    <script>
        // TẮT stellar parallax để hết rung khi cuộn
        (function () {
          if (!window.jQuery) return;
          try { $(window).stellar('destroy'); } catch (e) {}
          try { $(window).off('scroll.stellar'); } catch (e) {}
        })();
    </script>

    <!-- ✅ CHỈ 1 sticky script duy nhất -->
    <script>
        (function ($) {
          $(function () {
            var $nav = $('#templateux-navbar');
            if (!$nav.length) return;

            // spacer để không bị đè nội dung khi fixed
            var $sp = $('#qlksNavSpacer');
            if (!$sp.length) {
              $sp = $('<div id="qlksNavSpacer"></div>');
              $nav.after($sp);
            }

            var hasHero = $('.site-hero').length > 0;
            var threshold = hasHero ? 40 : -1; // không hero -> sticky ngay từ top

            function setSticky(on) {
              if (on) {
                $sp.height($nav.outerHeight());
                $nav.addClass('qlks-sticky')
                    .removeClass('navbar-dark')
                    .addClass('navbar-light');
              } else {
                $nav.removeClass('qlks-sticky')
                    .removeClass('navbar-light')
                    .addClass('navbar-dark');
                $sp.height(0);
              }
            }

            function applySticky() {
              var y = $(window).scrollTop() || 0;
              setSticky(y > threshold);
            }

            applySticky();
            $(window).on('scroll', applySticky);
            $(window).on('resize', function () {
              if ($nav.hasClass('qlks-sticky')) $sp.height($nav.outerHeight());
            });
          });
        })(jQuery);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>