@model QLKS.Models.NguoiDung
@using QLKS.Models
@using QLKS.Helpers
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card card-outline card-primary stretch stretch-full">
            <div class="card-header">
                <h3 class="card-title mb-0"><i class="fas fa-user me-2"></i> Thông tin</h3>
                <div class="card-tools">
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </div>
            <div class="card-body">
                <p><b>ID:</b> @Model.Id</p>
                <p><b>Tên đăng nhập:</b> @Model.TenDangNhap</p>
                <p><b>Họ tên:</b> @Model.HoTen</p>
                <p><b>SĐT:</b> @(Model.SoDienThoai ?? "-")</p>
                <p><b>Email:</b> @(Model.Email ?? "-")</p>
                <p><b>CCCD:</b> @(Model.CCCD ?? "-")</p>
                <p><b>Vai trò:</b> @Model.VaiTro.GetDisplayName()</p>
                <p>
                    <b>Trạng thái:</b>
                    @if (Model.TrangThai)
                    {
                        <span class="badge rounded-pill bg-success">Hoạt động</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-danger">Bị khoá</span>
                    }
                </p>
                <p><b>Ngày tạo:</b> @Model.NgayTao.ToString("yyyy-MM-dd")</p>

                <div class="mt-3 d-flex gap-2">
                    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">
                        <i class="fas fa-edit me-1"></i> Sửa
                    </a>
                    <a class="btn btn-info" asp-action="ResetPassword" asp-route-id="@Model.Id">
                        <i class="fas fa-key me-1"></i> Đặt lại mật khẩu
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card card-outline card-secondary stretch stretch-full">
            <div class="card-header">
                <h3 class="card-title mb-0"><i class="fas fa-calendar-check me-2"></i> Đặt phòng (@Model.DatPhongs.Count)</h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:70px;">Mã</th>
                                <th>Nhận</th>
                                <th>Trả</th>
                                <th style="width:140px;">Trạng thái</th>
                                <th class="text-end" style="width:140px;">Tổng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.DatPhongs.Count == 0)
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">Chưa có đặt phòng.</td></tr>
                            }
                            else
                            {
                                foreach (var dp in Model.DatPhongs.OrderByDescending(x => x.Id).Take(10))
                                {
                                    <tr>
                                        <td>@dp.Id</td>
                                        <td>@dp.NgayNhanPhong.ToString("yyyy-MM-dd")</td>
                                        <td>@dp.NgayTraPhong.ToString("yyyy-MM-dd")</td>
                                        <td><span class="@dp.TrangThai.BadgeClass()">@dp.TrangThai.GetDisplayName()</span></td>
                                        <td class="text-end">@string.Format("{0:N0}", dp.TongTien)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted small">
                Hiển thị 10 đặt phòng gần nhất.
            </div>
        </div>
    </div>
</div>
