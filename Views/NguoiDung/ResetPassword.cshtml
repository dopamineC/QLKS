@model QLKS.ViewModels.AdminResetPasswordVM
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    var u = ViewBag.User as QLKS.Models.NguoiDung;
}

<div class="card card-outline card-info stretch stretch-full">
    <div class="card-header">
        <h3 class="card-title mb-0">
            <i class="fas fa-key me-2"></i> Đặt lại mật khẩu
        </h3>
        <div class="card-tools">
            <a class="btn btn-outline-secondary btn-sm" asp-action="Index">
                <i class="fas fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card-body">
        @if (u != null)
        {
            <div class="alert alert-light border">
                <div><b>Người dùng:</b> @u.HoTen (@u.TenDangNhap)</div>
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Mật khẩu mới</label>
                    <input class="form-control" asp-for="MatKhauMoi" type="password" />
                    <span class="text-danger" asp-validation-for="MatKhauMoi"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Xác nhận mật khẩu</label>
                    <input class="form-control" asp-for="XacNhanMatKhauMoi" type="password" />
                    <span class="text-danger" asp-validation-for="XacNhanMatKhauMoi"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-info" type="submit">
                    <i class="fas fa-save me-1"></i> Cập nhật mật khẩu
                </button>
                <a class="btn btn-outline-secondary" asp-action="Index">Huỷ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
