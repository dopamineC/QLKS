@model QLKS.Models.LoaiPhong

@{
    ViewData["Title"] = "";
    var placeholder = Url.Content("~/adminlte/assets/img/default-150x150.png");
    var img = string.IsNullOrWhiteSpace(Model.HinhAnh) ? placeholder : Model.HinhAnh;
}

@section Styles {
    <link rel="stylesheet" href="~/adminlte/css/admin-roomtype.css" asp-append-version="true" />
}

<div class="mgr-wrap invoice-wrap invoice-full type-wrap type-form">

    <div class="mgr-head invoice-topbar">
        <h2 class="invoice-heading">
            <i class="fas fa-eye"></i>
            <span>Chi tiết loại phòng</span>
        </h2>

        <div class="rt-top-actions">
            <a class="btnx warning" asp-action="Edit" asp-route-id="@Model.Id">
                <i class="fas fa-pen"></i> Sửa
            </a>
            <a class="btnx danger" asp-action="Delete" asp-route-id="@Model.Id">
                <i class="fas fa-trash"></i> Xóa
            </a>
            <a class="btnx" asp-action="Index">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="rt-body">

        <div class="rt-grid">

            <!-- LEFT: Info -->
            <div class="rt-panel">
                <div class="rt-panel-hd">
                    <div class="rt-panel-title">
                        <i class="fas fa-info-circle"></i> Thông tin
                    </div>
                </div>

                <div class="rt-panel-bd">
                    <div class="rt-kv">
                        <div class="rt-k">Tên loại</div>
                        <div class="rt-v">@Model.TenLoai</div>
                    </div>

                    <div class="rt-kv">
                        <div class="rt-k">Số người</div>
                        <div class="rt-v">
                            <span class="pill p-cap">@Model.SoNguoi người</span>
                        </div>
                    </div>

                    <div class="rt-kv">
                        <div class="rt-k">Giá/đêm</div>
                        <div class="rt-v">
                            <span class="pill" style="background:#ecfdf5;color:#047857;">@Model.GiaMoiDem.ToString("N0") ₫</span>
                        </div>
                    </div>

                    <div class="rt-kv" style="padding-bottom:0;">
                        <div class="rt-k">Mô tả</div>
                        <div class="rt-v">
                            <div class="rt-descbox">
                                @(string.IsNullOrWhiteSpace(Model.MoTa) ? "—" : Model.MoTa)
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Image -->
            <div class="rt-panel">
                <div class="rt-panel-hd">
                    <div class="rt-panel-title">
                        <i class="fas fa-image"></i> Hình ảnh
                    </div>
                </div>

                <div class="rt-panel-bd">
                    <div class="rt-preview">
                        <img src="@img" alt="@Model.TenLoai" />
                        <div class="rt-preview-cap">
                            <span>Xem ảnh</span>
                            <small>click ảnh để mở</small>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script>
        (function () {
            const img = document.querySelector(".rt-preview img");
            if (!img) return;
            img.addEventListener("click", function () {
                window.open(img.src, "_blank");
            });
        })();
    </script>
}
