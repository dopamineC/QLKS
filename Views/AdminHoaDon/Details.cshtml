@model QLKS.Models.HoaDon
@using QLKS.Helpers
@using QLKS.Models
@{
    ViewData["Title"] = $"Hóa đơn #{Model.Id}";
    var dp = Model.DatPhong;
    var kh = dp?.KhachHang;
    var phong = dp?.Phong;
    var loai = phong?.LoaiPhong;
}

<div class="card card-outline card-primary stretch stretch-full">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0"><i class="fas fa-file-invoice-dollar me-2"></i> Chi tiết hóa đơn</h3>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">
            <i class="fas fa-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="card-body">
        <div class="row g-3">
            <div class="col-lg-6">
                <div class="border rounded p-3">
                    <h5 class="mb-3">Thông tin hóa đơn</h5>
                    <p><b>Mã hóa đơn:</b> @Model.Id</p>
                    <p><b>Mã đặt phòng:</b> @Model.DatPhongId</p>
                    <p><b>Số tiền:</b> @string.Format("{0:N0}", Model.SoTien)</p>
                    <p><b>Trạng thái:</b> <span class="@Model.TrangThai.BadgeClass()">@Model.TrangThai.GetDisplayName()</span></p>
                    <p><b>Phương thức:</b> @Model.PhuongThuc.GetDisplayName()</p>
                    <p><b>Ngày thanh toán:</b> @(Model.NgayThanhToan?.ToString("yyyy-MM-dd HH:mm") ?? "-")</p>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="border rounded p-3">
                    <h5 class="mb-3">Thông tin đặt phòng</h5>
                    <p><b>Khách:</b> @((kh?.HoTen) ?? "-") (@((kh?.TenDangNhap) ?? "-"))</p>
                    <p><b>SĐT:</b> @((kh?.SoDienThoai) ?? "-")</p>
                    <p><b>Phòng:</b> @(phong?.SoPhong ?? "-")</p>
                    <p><b>Loại:</b> @(loai?.TenLoai ?? "-")</p>
                    <p><b>Nhận:</b> @(dp?.NgayNhanPhong.ToString("yyyy-MM-dd") ?? "-")</p>
                    <p><b>Trả:</b> @(dp?.NgayTraPhong.ToString("yyyy-MM-dd") ?? "-")</p>
                    <p><b>Tổng tiền đặt phòng:</b> @(dp != null ? string.Format("{0:N0}", dp.TongTien) : "-")</p>
                </div>
            </div>
        </div>

        <div class="mt-3">
            @if (Model.TrangThai != TrangThaiHoaDon.DaHuy)
            {
                @if (Model.TrangThai == TrangThaiHoaDon.ChuaThanhToan)
                {
                    <form asp-action="MarkPaid" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="method" value="TienMat" />
                        <button class="btn btn-success" type="submit"
                                onclick="return confirm('Xác nhận thanh toán tiền mặt?');">
                            Thanh toán (Tiền mặt)
                        </button>
                    </form>

                    <form asp-action="MarkPaid" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="method" value="ChuyenKhoan" />
                        <button class="btn btn-success" type="submit"
                                onclick="return confirm('Xác nhận thanh toán chuyển khoản?');">
                            Thanh toán (Chuyển khoản)
                        </button>
                    </form>
                }
                else if (Model.TrangThai == TrangThaiHoaDon.DaThanhToan)
                {
                    <form asp-action="MarkUnpaid" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button class="btn btn-warning" type="submit"
                                onclick="return confirm('Chuyển về CHƯA thanh toán?');">
                            Hoàn tác (Chưa thanh toán)
                        </button>
                    </form>
                }

                <form asp-action="Cancel" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button class="btn btn-danger" type="submit"
                            onclick="return confirm('Huỷ hóa đơn này?');">
                        Huỷ hóa đơn
                    </button>
                </form>
            }
        </div>
    </div>
</div>
