@model QLKS.ViewModels.HomeIndexVM
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Trang chủ";
    var loaiPhongItems = new SelectList(Model.LoaiPhongs, "Id", "TenLoai");
    var hero = Url.Content("~/redplanet/images/hero_5.jpg");
}

<section class="site-hero overlay"
         style="background-image: url('@hero')"
         data-stellar-background-ratio="0.5"
         id="section-home">
    <div class="container">
        <div class="row site-hero-inner justify-content-center align-items-center">
            <div class="col-md-10 text-center" data-aos="fade-up">
                <h1 class="heading">Đặt phòng khách sạn nhanh gọn</h1>
                <p class="lead text-white-50 mt-3">
                    Chọn ngày nhận/trả, lọc loại phòng và số người để tìm phòng trống.
                </p>
            </div>
        </div>
    </div>

    <a class="mouse smoothscroll" href="#next">
        <div class="mouse-icon"><span class="mouse-wheel"></span></div>
    </a>
</section>

<!-- SEARCH CARD (y mẫu) -->
<section class="section bg-light pb-0">
    <div class="container">
        <div class="row check-availabilty" id="next">
            <div class="block-32" data-aos="fade-up" data-aos-offset="-200">

                <form asp-controller="Booking" asp-action="Search" method="post">
                    @Html.AntiForgeryToken()

                    <!-- hidden ISO để server bind DateTime chắc chắn -->
                    <input type="hidden" name="NgayNhan" id="NgayNhan" value="@Model.TimPhong.NgayNhan.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="NgayTra" id="NgayTra" value="@Model.TimPhong.NgayTra.ToString("yyyy-MM-dd")" />

                    <div class="row">
                        <div class="col-md-6 mb-3 mb-lg-0 col-lg-3">
                            <label class="font-weight-bold text-black">Ngày nhận</label>
                            <div class="field-icon-wrap">
                                <div class="icon"><span class="icon-calendar"></span></div>
                                <input type="text" id="checkin_date" class="form-control" autocomplete="off">
                            </div>
                        </div>

                        <div class="col-md-6 mb-3 mb-lg-0 col-lg-3">
                            <label class="font-weight-bold text-black">Ngày trả</label>
                            <div class="field-icon-wrap">
                                <div class="icon"><span class="icon-calendar"></span></div>
                                <input type="text" id="checkout_date" class="form-control" autocomplete="off">
                            </div>
                        </div>

                        <div class="col-md-6 mb-3 mb-md-0 col-lg-3">
                            <div class="row">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label class="font-weight-bold text-black">Số người</label>
                                    <div class="field-icon-wrap">
                                        <div class="icon"><span class="ion-ios-arrow-down"></span></div>
                                        <select class="form-control" name="SoNguoi">
                                            <option value="">-- Bất kỳ --</option>
                                            @for (int i = 1; i <= 10; i++)
                                            {
                                                <option value="@i" selected="@(Model.TimPhong.SoNguoi == i)">
                                                    @i
                                                </option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label class="font-weight-bold text-black">Loại phòng</label>
                                    <div class="field-icon-wrap">
                                        <div class="icon"><span class="ion-ios-arrow-down"></span></div>
                                        <select class="form-control" name="LoaiPhongId" asp-items="loaiPhongItems">
                                            <option value="">-- Tất cả --</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-3 align-self-end">
                            <button class="btn btn-primary btn-block text-white">Tìm phòng trống</button>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>
</section>

<!-- ABOUT (y mẫu) -->
<section class="py-5 bg-light" id="section-about">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-12 col-lg-7 ml-auto order-lg-2 position-relative mb-5" data-aos="fade-up">
                <img src="@Url.Content("~/redplanet/images/hero_4.jpg")" alt="About" class="img-fluid rounded">
            </div>

            <div class="col-md-12 col-lg-4 order-lg-1" data-aos="fade-up">
                <h2 class="heading mb-4">Về khách sạn</h2>
                <p class="mb-4">
                    Không gian nghỉ dưỡng hiện đại, phòng sạch sẽ, vị trí thuận tiện.
                    Hệ thống đặt phòng giúp bạn kiểm tra phòng trống theo ngày và đặt nhanh chỉ trong vài bước.
                </p>
                <p class="mb-5">
                    Ưu tiên trải nghiệm: rõ ràng giá, minh bạch thông tin, hỗ trợ nhanh khi cần.
                </p>

                <p>
                    <a href="#"
                       data-fancybox
                       class="btn btn-primary text-white py-2 mr-3 text-uppercase letter-spacing-1">
                        Xem video
                    </a>
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ROOMS (dynamic theo DB - FIX lệch + ảnh cover chuẩn) -->
<section class="section" id="section-rooms">
    <div class="container">
        <div class="row justify-content-center text-center mb-5">
            <div class="col-md-7">
                <h2 class="heading" data-aos="fade-up">Rooms &amp; Suites</h2>
                <p data-aos="fade-up" data-aos-delay="100">
                    Chọn loại phòng phù hợp và xem chi tiết giá / sức chứa.
                </p>
            </div>
        </div>

        <div class="row justify-content-center">
            @foreach (var lp in Model.LoaiPhongs.Take(6))
            {
                var img = string.IsNullOrWhiteSpace(lp.HinhAnh)
                ? Url.Content("~/redplanet/images/img_1.jpg")
                : Url.Content(lp.HinhAnh);

                <div class="col-md-6 col-lg-4 mb-4" data-aos="fade-up">
                    <a asp-controller="LoaiPhongPublic" asp-action="Details" asp-route-id="@lp.Id" class="room">
                        <figure class="img-wrap">
                            <img src="@img"
                                 alt="@lp.TenLoai"
                                 class="img-fluid w-100 room-cover"
                                 loading="lazy" />
                        </figure>
                        <div class="p-3 text-center room-info">
                            <h2>@lp.TenLoai</h2>
                            <span class="text-uppercase letter-spacing-1">
                                @string.Format("{0:N0}", lp.GiaMoiDem) VND / đêm
                            </span>
                        </div>
                    </a>
                </div>
            }
        </div>

        <div class="d-flex justify-content-center mt-4" data-aos="fade-up">
            <a class="btn btn-outline-primary" asp-controller="LoaiPhongPublic" asp-action="Index">
                Xem tất cả loại phòng
            </a>
        </div>
    </div>
</section>

<!-- PHOTOS SLIDER (y mẫu) -->
<section class="section slider-section bg-light" id="section-photos">
    <div class="container">
        <div class="row justify-content-center text-center mb-5">
            <div class="col-md-7">
                <h2 class="heading" data-aos="fade-up">Photos</h2>
                <p data-aos="fade-up" data-aos-delay="100">
                    Một vài hình ảnh không gian và tiện nghi.
                </p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="home-slider major-caousel owl-carousel mb-5" data-aos="fade-up" data-aos-delay="200">
                    @for (int i = 1; i <= 7; i++)
                    {
                        var s = Url.Content($"~/redplanet/images/slider-{i}.jpg");
                        <div class="slider-item">
                            <a href="@s" data-fancybox="images" data-caption="Ảnh @i">
                                <img src="@s" alt="Slider @i" class="img-fluid">
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- TESTIMONIALS (y mẫu) -->
