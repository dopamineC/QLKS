<!-- CONTACT (y mẫu) -->
<section class="section contact-section" id="section-contact">
    <div class="container">
        <div class="row justify-content-center text-center mb-5">
            <div class="col-md-7">
                <h2 class="heading" data-aos="fade-up">Liên hệ</h2>
                <p data-aos="fade-up">
                    Cần hỗ trợ đặt phòng / đổi lịch? Gửi thông tin, tụi mình sẽ liên hệ lại.
                </p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-7" data-aos="fade-up" data-aos-delay="100">
                <!-- form UI thôi (không submit để khỏi lỗi antiforgery) -->
                <form class="bg-white p-md-5 p-4 mb-5 border" onsubmit="return false;">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>Họ tên</label>
                            <input type="text" class="form-control" placeholder="Nhập họ tên">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Số điện thoại</label>
                            <input type="text" class="form-control" placeholder="Nhập số điện thoại">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 form-group">
                            <label>Email</label>
                            <input type="email" class="form-control" placeholder="Nhập email">
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12 form-group">
                            <label>Nội dung</label>
                            <textarea class="form-control" cols="30" rows="8" placeholder="Bạn cần hỗ trợ gì?"></textarea>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <button type="button" class="btn btn-primary text-white font-weight-bold">
                                Gửi liên hệ
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="col-md-5" data-aos="fade-up" data-aos-delay="200">
                <div class="row">
                    <div class="col-md-10 ml-auto contact-info">
                        <p><span class="d-block">Địa chỉ:</span> <span class="text-black">Hoàn Kiếm, Hà Nội</span></p>
                        <p><span class="d-block">Điện thoại:</span> <span class="text-black">(+84) 09xx xxx xxx</span></p>
                        <p><span class="d-block">Email:</span> <span class="text-black">support@qlks.local</span></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // main.js đã init datepicker rồi -> ở đây chỉ setDate + sync hidden ISO để server nhận đúng
        (function () {
            if (!window.jQuery || !$.fn.datepicker) return;

            function isoToDate(iso) {
                const p = (iso || "").split("-");
                if (p.length !== 3) return null;
                const y = parseInt(p[0], 10), m = parseInt(p[1], 10) - 1, d = parseInt(p[2], 10);
                if (isNaN(y) || isNaN(m) || isNaN(d)) return null;
                return new Date(y, m, d);
            }
            function pad(n) { return n < 10 ? "0" + n : "" + n; }
            function dateToIso(dt) {
                return dt.getFullYear() + "-" + pad(dt.getMonth() + 1) + "-" + pad(dt.getDate());
            }

            const inIso = document.getElementById("NgayNhan")?.value;
            const outIso = document.getElementById("NgayTra")?.value;

            const dIn = isoToDate(inIso) || new Date();
            const dOut = isoToDate(outIso) || new Date(Date.now() + 86400000);

            // set lên input datepicker (đúng format hiển thị)
            $('#checkin_date').datepicker('setDate', dIn);
            $('#checkout_date').datepicker('setDate', dOut);

            // sync ngược lại vào hidden yyyy-mm-dd
            $('#checkin_date').on('changeDate', function () {
                const dt = $('#checkin_date').datepicker('getDate');
                if (dt) document.getElementById("NgayNhan").value = dateToIso(dt);
            });
            $('#checkout_date').on('changeDate', function () {
                const dt = $('#checkout_date').datepicker('getDate');
                if (dt) document.getElementById("NgayTra").value = dateToIso(dt);
            });
        })();
    </script>
}